--> Problem
  -Find cities having:
             more than 3 students
             average marks > 70
             Answer
             SELECT city,
             COUNT(*) AS total_students,
             AVG(marks) AS average_marks
             FROM students
             GROUP BY city
             HAVING COUNT(*) > 3
             AND AVG(marks) > 70;

             Find departments where:

             total salary > 500000
             average salary > 60000
             Answer
             SELECT department,
             SUM(salary) AS total_salary,
             AVG(salary) AS avg_salary
             FROM employees
             GROUP BY department
             HAVING SUM(salary) > 500000
             AND AVG(salary) > 60000;


